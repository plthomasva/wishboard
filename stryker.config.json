{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "stryker.vite.config.ts"
  },
  "reporters": ["progress", "clear-text", "html", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "coverageAnalysis": "off",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "mutate": [
    "src/client/src/**/*.ts",
    "src/client/src/**/*.tsx",
    "src/client/src/**/*.js",
    "src/server/**/*.js",
    "src/server/**/*.ts",
    "src/cli/**/*.js",
    "!src/client/src/**/*.test.ts",
    "!src/client/src/**/*.test.tsx",
    "!src/client/src/**/*.test.js",
    "!src/server/**/*.test.js",
    "!src/server/**/*.test.ts",
    "!src/cli/**/*.test.js",
    "!src/client/src/components/WishScanner.tsx",
    "!src/client/src/constants.ts",
    "!src/client/src/pages/AboutPage.tsx",
    "!src/client/src/pages/PosterPage.tsx",
    "!src/client/src/components/WishPreview.tsx"
  ],
  "ignorePatterns": ["!dist/**/*"]
}
