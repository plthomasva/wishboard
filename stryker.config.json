{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "stryker.vite.config.ts"
  },
  "reporters": ["progress", "clear-text", "html", "json", "dashboard"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "dashboard": {
    "project": "github.com/plthomasva/wishboard",
    "version": "main",
    "reportType": "full"
  },
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "mutate": [
    "src/client/src/**/*.ts",
    "src/client/src/**/*.tsx",
    "src/client/src/**/*.js",
    "src/server/**/*.js",
    "src/server/**/*.ts",
    "src/cli/**/*.js",
    "!src/client/src/**/*.test.ts",
    "!src/client/src/**/*.test.tsx",
    "!src/client/src/**/*.test.js",
    "!src/server/**/*.test.js",
    "!src/server/**/*.test.ts",
    "!src/cli/**/*.test.js",
    "!src/client/src/components/WishScanner.tsx"
  ],
  "ignorePatterns": ["!dist/**/*"]
}
