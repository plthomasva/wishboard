{
  "name": "wishboard",
  "version": "1.20.1",
  "private": true,
  "bin": {
    "wishboard": "./src/cli/wishboard.js"
  },
  "type": "module",
  "scripts": {
    "predev": "node ./src/cli/wishboard.js build prepare-profile",
    "dev": "concurrently \"vite\" \"node --watch ./src/server/index.js\"",
    "prebuild": "node ./src/cli/wishboard.js build download-fonts",
    "build": "vite build",
    "build:cli": "esbuild src/cli/wishboard.js --bundle --platform=node --format=esm --outfile=dist/wishboard.js",
    "preview": "vite preview",
    "start": "npm run build && node ./src/server/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node .husky/install.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1089.0",
    "@aws-sdk/client-cloudwatch": "3.1090.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1089.0",
    "@aws-sdk/client-s3": "^3.1084.0",
    "@aws-sdk/client-ssm": "^3.1094.0",
    "@codegenie/serverless-express": "^5.0.0",
    "@libsql/client": "^0.17.4",
    "commander": "^15.0.0",
    "cors": "^2.8.5",
    "esbuild": "^0.28.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nanoid": "^5.1.16",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@techstark/opencv-js": "^5.0.0-release.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "c8": "^12.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "3.9.2",
    "resize-observer-polyfill": "^1.5.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.3",
    "tesseract.js": "^7.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "debug": "^4.3.4",
    "qs": "^6.15.2"
  }
}
