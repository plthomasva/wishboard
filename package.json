{
  "name": "wishboard",
  "version": "1.10.1",
  "private": true,
  "bin": {
    "wishboard": "./src/cli/wishboard.js"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node --watch ./src/server/index.js\"",
    "prebuild": "node ./scripts/download-fonts.js",
    "build": "vite build",
    "build:cli": "esbuild src/cli/wishboard.js --bundle --platform=node --format=esm --outfile=dist/wishboard.js",
    "preview": "vite preview",
    "start": "npm run build && node ./src/server/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1075.0",
    "@aws-sdk/client-cloudwatch": "3.1075.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@codegenie/serverless-express": "^5.0.0",
    "@libsql/client": "^0.17.4",
    "@techstark/opencv-js": "^5.0.0-release.1",
    "commander": "^15.0.0",
    "cors": "^2.8.5",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nanoid": "^5.1.16",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "3.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tesseract.js": "^7.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "c8": "^11.0.0",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "resize-observer-polyfill": "^1.5.1",
    "supertest": "^7.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "debug": "^4.3.4",
    "qs": "^6.15.2"
  }
}
